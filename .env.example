# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Contentful ───────────────────────────────────────────────────────────────
# From: https://app.contentful.com → Space Settings → API Keys
VITE_CONTENTFUL_SPACE_ID=your-space-id
VITE_CONTENTFUL_ACCESS_TOKEN=your-content-delivery-api-access-token

# ─── Web3Forms ────────────────────────────────────────────────────────────────
# From: https://web3forms.com → Create Form
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_URL=https://your-vercel-domain.vercel.app
